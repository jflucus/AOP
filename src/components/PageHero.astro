---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
}
const { eyebrow, title, intro } = Astro.props;
---

<section class="page-hero">
  <div class="container">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {intro && <p class="lead">{intro}</p>}
  </div>
</section>

<style>
  .page-hero {
    background: var(--navy);
    color: #fff;
    padding-block: clamp(2.6rem, 6vw, 4.5rem);
    position: relative;
    overflow: hidden;
  }
  .page-hero::after {
    content: '';
    position: absolute;
    right: -80px;
    top: -80px;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(198, 139, 33, 0.28), transparent 65%);
    pointer-events: none;
  }
  .page-hero h1 {
    color: #fff;
    max-width: 20ch;
  }
  .page-hero .lead {
    color: #c3d0e2;
    max-width: 62ch;
    position: relative;
  }
  .page-hero .eyebrow {
    color: var(--gold-light);
  }
</style>
