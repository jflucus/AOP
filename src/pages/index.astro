---
import Base from '../layouts/Base.astro';
import { outcomes, successModel, spotlights, commitments, totalScholarshipsEarned } from '../data';
import { site } from '../config';

const formattedScholarships = `$${totalScholarshipsEarned.toLocaleString('en-US')}`;
const formattedScholarshipsShort = `$${(totalScholarshipsEarned / 1_000_000).toFixed(2)}M+`;
---

<Base>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__copy">
        <p class="eyebrow">Promise. Preparation. Purpose.</p>
        <h1> Every Student Has Promise. We Help Them Discover It. </h1>
        <p class="lead">
  AOP Foundation empowers student-athletes with the mentorship,
  academic support, leadership development, and affordable college and career planning
  they need to build successful futures.
</p>
        <div class="hero__cta">
          <a class="btn btn--gold" href="/donate/">Donate</a>
          <a class="btn btn--ghost" href="/get-involved/">Get Involved</a>
        </div>
      </div>
      <div class="hero__art" aria-hidden="true">
        <div class="hero__logo-panel">
          <img src="/brand/logo-primary.png" alt="" width="983" height="918" />
        </div>
      </div>
    </div>
  </section>

  <!-- First Cohort Results -->
  <section class="section section--navy cohort-results">
    <div class="container center">
      <p class="eyebrow">Our First Cohort</p>
      <h2>Real results, before we even ask</h2>
      <div class="grid grid--4 stats" style="margin-top:2rem;">
        <div class="stat">
          <span class="stat__num">16</span>
          <p>Seniors in AOP's first cohort</p>
        </div>
        <div class="stat">
          <span class="stat__num">100%</span>
          <p>Graduated on time</p>
        </div>
        <div class="stat">
          <span class="stat__num">100%</span>
          <p>Accepted to college</p>
        </div>
        <div class="stat">
          <span class="stat__num">{formattedScholarshipsShort}</span>
          <p>In college scholarships earned</p>
        </div>
      </div>
      <p class="lead" style="margin-top:2rem;">
        Every senior we mentored graduated and is headed to college, together earning {formattedScholarships} in
        scholarships. Your support is what makes the next cohort possible.
      </p>
      <a class="btn btn--gold" href="/donate/">Support the next cohort</a>
    </div>
  </section>

  <!-- Scholar Spotlight -->
  <section class="section">
    <div class="container">
      <div class="center">
        <p class="eyebrow">Scholar Spotlight</p>
        <h2>Proof of what mentorship builds</h2>
      </div>
      <div class="grid grid--2 spotlight-grid" style="margin-top:2.5rem;">
        {spotlights.map((s) => (
          <div class="spotlight">
            <div class="spotlight__photo-wrap">
              <img class="spotlight__photo" src={s.photo} alt={s.alt} loading="lazy" />
            </div>
            <div class="spotlight__copy">
              <h3>{s.title}</h3>
              <p class="lead">{s.blurb}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Outcomes -->
  <section class="section section--alt">
    <div class="container">
      <div class="center">
        <p class="eyebrow">The Three Promise Outcomes</p>
        <h2>We measure ourselves on outcomes, not activity</h2>
        <p class="lead">
          Everything AOP does is organized around three measurable outcomes, the metrics by which
          we hold ourselves accountable and report to funders.
        </p>
      </div>
      <div class="grid grid--3" style="margin-top:2.5rem;">
        {outcomes.map((o) => (
          <article class="card">
            <div class="card__icon">{o.icon}</div>
            <h3>{o.title}</h3>
            <p>{o.summary}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- College Commitments -->
  <section class="section">
    <div class="container">
      <div class="center">
        <p class="eyebrow">Class of 2026</p>
        <h2>{formattedScholarshipsShort} in college scholarships, and counting</h2>
        <p class="lead">
          Four of our scholars just committed to college, together earning {formattedScholarships} in
          scholarships. This is what's possible when a student gets a mentor, a plan, and someone in
          their corner.
        </p>
      </div>
      <div class="grid commitment-grid" style="margin-top:2.5rem;">
        {commitments.map((c) => (
          <figure class="commitment">
            <img class="commitment__photo" src={c.photo} alt={`${c.name} officially committed to ${c.school}`} loading="lazy" />
            <figcaption>
              <p class="commitment__name">{c.name} &rarr; {c.school}</p>
              <p class="commitment__detail">{c.major} · ${c.scholarship.toLocaleString('en-US')} earned</p>
            </figcaption>
          </figure>
        ))}
      </div>
      <div class="center" style="margin-top:2rem;">
        <a class="btn btn--navy" href="/college-acceptances/">See every school our scholars got into</a>
      </div>
    </div>
  </section>

  <!-- Mission strip -->
  <section class="section section--navy">
    <div class="container center">
      <p class="eyebrow">Our Mission</p>
      <p class="mission">
        To prepare student-athletes and students with athletic aspirations for success in college and
        beyond, developing their academic achievement, athletic performance, leadership, and character,
        while helping families identify <strong>affordable</strong> education pathways aligned with each
        student's passions, talents, and career goals.
      </p>
      <a class="btn btn--ghost" href="/about/">More about AOP</a>
    </div>
  </section>

  <!-- Programs -->
  <section class="section section--alt">
    <div class="container">
      <div class="center">
        <p class="eyebrow">Our Program</p>
        <h2>The AOP Scholar-Athlete Success Model</h2>
        <p class="lead">
          One signature program with seven integrated phases, and a trained mentor with every scholar the whole way.
        </p>
      </div>
      <ol class="model-steps">
        {successModel.map((phase) => (
          <li>
            <a href={`/programs/#${phase.slug}`}>
              <span class="model-steps__num">{phase.n}</span>
              <span class="model-steps__name">{phase.name}</span>
            </a>
          </li>
        ))}
      </ol>
      <div class="center" style="margin-top:2rem;">
        <a class="btn btn--navy" href="/programs/">Explore the model</a>
      </div>
    </div>
  </section>

  <!-- Evidence band -->
  <section class="section">
    <div class="container">
      <div class="center">
        <p class="eyebrow">Built on evidence</p>
        <h2>Our design follows what research shows works</h2>
      </div>
      <div class="grid grid--3 stats" style="margin-top:2rem;">
        <div class="stat">
          <span class="stat__num">55%</span>
          <p>Bachelor's completion under intensive advising (vs. 47%) in a multi-site RCT including NYC.</p>
        </div>
        <div class="stat">
          <span class="stat__num">84%</span>
          <p>More likely to enroll immediately in college when a senior completes the FAFSA.</p>
        </div>
        <div class="stat">
          <span class="stat__num">~2%</span>
          <p>Of high school athletes receive athletic scholarships, so we build the plan on aid, honestly.</p>
        </div>
      </div>
      <p class="disclaimer center">
        Figures from Bottom Line (Barr &amp; Castleman RCT), NCAN, and the NCAA. Sources are listed on our
        <a href="/about/#evidence">About</a> page and verified before use in funder materials.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--navy cta-band">
    <div class="container center">
      <h2>Help a young person turn talent into a future</h2>
      <p class="lead">
        Your support funds tutoring, athletic equipment, leadership workshops, college visits, mentoring,
        and scholarship assistance for NYC student-athletes.
      </p>
      <div class="hero__cta center-cta">
        <a class="btn btn--gold" href="/donate/">Donate</a>
        <a class="btn btn--ghost" href="/get-involved/">Volunteer or Mentor</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    background: linear-gradient(160deg, var(--navy) 0%, #071a37 100%);
    color: #fff;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 82% 20%, rgba(198, 139, 33, 0.22), transparent 45%);
    pointer-events: none;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    align-items: center;
    gap: 2.5rem;
    padding-block: clamp(3rem, 8vw, 6rem);
    position: relative;
  }
  .hero__copy h1 {
    color: #fff;
  }
  .hero__copy .lead {
    color: #c9d6e8;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.8rem;
  }
  .hero__art {
    display: grid;
    place-items: center;
  }
  .hero__logo-panel {
    background: #fff;
    border-radius: 20px;
    padding: clamp(1.2rem, 3vw, 2rem);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
    width: min(100%, 400px);
  }
  .hero__logo-panel img {
    width: 100%;
    height: auto;
  }
  /* Ghost button on the navy hero needs light treatment */
  .hero .btn--ghost {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.6);
  }
  .hero .btn--ghost:hover {
    background: #fff;
    color: var(--navy);
  }

  .spotlight-grid {
    align-items: start;
  }
  .spotlight {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.2rem;
  }
  .spotlight__photo-wrap {
    width: 100%;
    max-width: 280px;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  .spotlight__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }
  .spotlight__copy {
    max-width: 34ch;
    margin-inline: auto;
  }
  .spotlight__copy h3 {
    margin: 0 0 0.5rem;
  }
  .spotlight__copy .lead {
    max-width: none;
  }

  .commitment-grid {
    grid-template-columns: repeat(4, 1fr);
  }
  .commitment {
    margin: 0;
    text-align: center;
  }
  .commitment__photo {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    display: block;
  }
  .commitment__name {
    margin: 1rem 0 0.2rem;
    font-weight: 700;
    color: var(--navy);
  }
  .commitment__detail {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .mission {
    font-family: var(--font-body);
    font-size: clamp(1.25rem, 2.6vw, 1.7rem);
    font-weight: 500;
    max-width: 46ch;
    margin-inline: auto;
    color: #eaf0f8;
    line-height: 1.4;
  }
  .mission strong {
    color: var(--gold-light);
  }

  .program-card {
    color: inherit;
    text-decoration: none;
    transition: transform 0.14s ease, box-shadow 0.14s ease;
    display: block;
  }
  .program-card:hover {
    text-decoration: none;
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .model-steps {
    list-style: none;
    counter-reset: none;
    margin: 2.5rem auto 0;
    padding: 0;
    max-width: 760px;
    display: grid;
    gap: 0.75rem;
  }
  .model-steps a {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #fff;
    border: 1px solid var(--border);
    border-left: 4px solid var(--gold);
    border-radius: 10px;
    padding: 0.9rem 1.1rem;
    color: var(--navy);
    font-weight: 600;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }
  .model-steps a:hover {
    text-decoration: none;
    transform: translateX(3px);
    box-shadow: var(--shadow);
  }
  .model-steps__num {
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--navy);
    color: var(--gold-light);
    font-family: var(--font-display);
    display: grid;
    place-items: center;
    font-size: 1.1rem;
  }

  .stat {
    text-align: center;
    padding: 1rem;
  }
  .stat__num {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 4.4rem);
    color: var(--navy);
    line-height: 1;
    display: block;
  }
  .stat p {
    color: var(--text-muted);
    max-width: 30ch;
    margin-inline: auto;
  }
  .grid--4 {
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }
  .cohort-results .stat__num {
    color: var(--gold-light);
    font-size: clamp(2.1rem, 5vw, 3.2rem);
  }
  .cohort-results .stat p {
    color: #c9d6e8;
  }
  .cohort-results .btn--gold {
    margin-top: 0.5rem;
  }
  .disclaimer {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 2rem;
    max-width: 60ch;
    margin-inline: auto;
  }
  .center-cta {
    justify-content: center;
  }

  @media (max-width: 860px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero__cta {
      justify-content: center;
    }
    .hero__art {
      order: -1;
    }
    .hero__logo-panel {
      width: 240px;
      margin-inline: auto;
    }
    .spotlight__photo-wrap {
      max-width: 260px;
    }
    .commitment-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
