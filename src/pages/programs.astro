---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { programs } from '../data';
---

<Base title="Our Programs" description="AOP's four programs: Academic Success Academy, Athletic Excellence Institute, College & Career Success Center, and Leadership Institute.">
  <PageHero
    eyebrow="Our Programs"
    title="Four programs, one integrated model"
    intro="Each program is re-anchored to the outcomes it drives, with a named owner and a metric. Every requirement is measured from Week 1."
  />

  <section class="section">
    <div class="container">
      <div class="program-list">
        {programs.map((p, i) => (
          <article class="program" id={p.slug}>
            <div class="program__head">
              <div class="card__icon program__icon">{p.icon}</div>
              <div>
                <span class="card__tag">Drives: {p.drives}</span>
                <h2>{p.name}</h2>
                <p class="program__tagline">{p.tagline}</p>
              </div>
            </div>
            <ul class="checklist program__points">
              {p.points.map((pt) => <li>{pt}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--navy cta-band">
    <div class="container center">
      <h2>Want to bring these programs to your school or community?</h2>
      <p class="lead">We partner with schools, employers, and community organizations across NYC.</p>
      <a class="btn btn--gold" href="/get-involved/">Become a Partner</a>
    </div>
  </section>
</Base>

<style>
  .program-list {
    display: grid;
    gap: 2rem;
  }
  .program {
    background: #fff;
    border: 1px solid var(--border);
    border-left: 5px solid var(--gold);
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: var(--shadow);
  }
  .program__head {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
    margin-bottom: 1.2rem;
  }
  .program__icon {
    flex: 0 0 auto;
    margin-bottom: 0;
  }
  .program h2 {
    margin: 0.3rem 0 0.2rem;
  }
  .program__tagline {
    color: var(--text-muted);
    margin: 0;
  }
  .program__points {
    max-width: 80ch;
  }
  @media (max-width: 560px) {
    .program__head {
      flex-direction: column;
      gap: 0.8rem;
    }
  }
</style>
