---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

// Add entries here as news and events happen. Newest first.
const posts: {
  date: string;
  tag: string;
  title: string;
  meta?: string[];
  body: string[];
  photo?: string;
}[] = [
  {
    date: 'September 1, 2026',
    tag: 'Milestone',
    title: 'AOP Foundation launches its pilot cohort',
    body: [
      'Our first scholars begin with a kickoff event, pre-season athletic training, and senior advising intake, the start of a program built around college acceptance, scholarship attainment, and career readiness.',
    ],
  },
  {
    date: 'July 2026',
    tag: 'Scholar Spotlight',
    title: 'Jennifer Bonilla is headed to City Tech for Radiologic Technology',
    meta: [
      'Gregorio Luperón High School for Science & Mathematics',
      'Future College: New York City College of Technology (City Tech) – Radiologic Technology (Fall 2026)',
    ],
    body: [
      'Jennifer exemplifies the dedication, perseverance, and leadership we strive to develop at AOP Foundation. A standout varsity catcher, she concluded her senior season with an outstanding .435 batting average, 3 home runs, 16 RBIs, and 12 stolen bases in just 10 regular-season games, helping lead her team with consistent offensive production. She elevated her game even further in the playoffs, batting .875.',
      'This fall, Jennifer will continue her academic journey at City Tech, where she will pursue a degree in Radiologic Technology. We are proud to celebrate her achievement and look forward to seeing the impact she will make both in healthcare and in her community.',
    ],
    photo: '/news/jennifer-bonilla-city-tech-2026.jpg',
  },
  {
    date: 'May 24, 2026',
    tag: 'Scholar Spotlight',
    title: 'Davon Sneed takes 3rd in the 400m Hurdles at PSAL Varsity City Championships',
    body: [
      'AOP scholar-athlete Davon Sneed earned a bronze medal in the 400m Hurdles at the PSAL Varsity City Championships at Icahn Stadium, competing for the Mott Haven Mavericks. Davon’s podium finish reflects the training, discipline, and mentorship at the center of our Athletic Excellence Institute, where athletic development goes hand in hand with academic accountability.',
    ],
    photo: '/news/davon-sneed-psal-2026.jpg',
  },
];
---

<Base title="News & Events" description="Announcements, milestones, and upcoming events from AOP Foundation.">
  <PageHero
    eyebrow="News & Events"
    title="What's happening at AOP"
    intro="Milestones, family events, and announcements as we launch and grow. Check back for FAFSA nights, worksite tours, and community events."
  />

  <section class="section">
    <div class="container narrow">
      {posts.length === 0 ? (
        <div class="empty card">
          <h3>Announcements coming soon</h3>
          <p>We're in our formation sprint. Follow along here for launch news and upcoming family events.</p>
        </div>
      ) : (
        <div class="posts">
          {posts.map((p) => (
            <article class="post card">
              {p.photo && <img class="post__photo" src={p.photo} alt={p.title} loading="lazy" />}
              <div class="post__meta">
                <span class="card__tag">{p.tag}</span>
                <time>{p.date}</time>
              </div>
              <h3>{p.title}</h3>
              {p.meta && (
                <div class="post__details">
                  {p.meta.map((line) => <p>{line}</p>)}
                </div>
              )}
              {p.body.map((para) => <p>{para}</p>)}
            </article>
          ))}
        </div>
      )}

      <div class="subscribe">
        <h2>Stay in the loop</h2>
        <p>Want launch news and event invites? Send us a note and we'll add you to our updates.</p>
        <a class="btn btn--gold" href="/contact/">Get updates</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .narrow {
    max-width: 760px;
  }
  .posts {
    display: grid;
    gap: 1.5rem;
  }
  .post__details {
    margin: 0.6rem 0 1rem;
  }
  .post__details p {
    color: var(--gold-dark);
    font-weight: 700;
    font-size: 0.9rem;
    margin: 0.2rem 0;
  }
  .post__photo {
    display: block;
    width: 100%;
    max-width: 320px;
    border-radius: 10px;
    margin-bottom: 1rem;
  }
  .post__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }
  .post__meta time {
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .subscribe {
    margin-top: 3rem;
    text-align: center;
    background: var(--sky);
    padding: 2.5rem;
    border-radius: var(--radius);
  }
  .subscribe h2 {
    margin-top: 0;
  }
</style>
