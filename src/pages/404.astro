---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found">
  <section class="section center" style="padding-block: clamp(4rem, 12vw, 8rem);">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>We couldn't find that page</h1>
      <p class="lead" style="margin-inline:auto;">The page may have moved. Let's get you back on track.</p>
      <p style="margin-top:1.5rem;">
        <a class="btn btn--gold" href="/">Back to home</a>
      </p>
    </div>
  </section>
</Base>
