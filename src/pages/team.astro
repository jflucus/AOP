---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { founder, mentors } from '../data';

function initials(name: string) {
  return name
    .split(' ')
    .map((n) => n[0])
    .slice(0, 2)
    .join('');
}
---

<Base title="Our Team" description="Meet the founder, founding mentors, board, and advisory council of AOP Foundation.">
  <PageHero
    eyebrow="Our Team"
    title="The people preparing our scholars"
    intro="Our founder, founding mentors, board, and advisory council are educators, coaches, and community leaders committed to every AOP scholar."
  />

  <!-- Founder -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Meet the Founder</p>
      <div class="founder">
        {founder.photo ? (
          <img class="avatar avatar--lg avatar--photo" src={founder.photo} alt={`${founder.name}, ${founder.role}`} width="400" height="400" />
        ) : (
          <div class="avatar avatar--lg" aria-hidden="true">{initials(founder.name)}</div>
        )}
        <div>
          <h2>{founder.name}</h2>
          <p class="role">{founder.role}</p>
          {founder.bio.map((para) => <p>{para}</p>)}
          <blockquote class="founder-quote">
            {founder.quote}
            <cite>{founder.name}</cite>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Mentors -->
  <section class="section section--alt">
    <div class="container">
      <p class="eyebrow">Meet Our Founding Mentors</p>
      <h2>Coaches and mentors trained in positive youth development</h2>
      <div class="grid grid--2 team-grid" style="margin-top:2rem;">
        {mentors.map((m) => (
          <article class="card mentor">
            {m.photo ? (
              <img class="avatar avatar--photo" src={m.photo} alt={`${m.name}, ${m.role}`} width="600" height="600" loading="lazy" />
            ) : (
              <div class="avatar" aria-hidden="true">{initials(m.name)}</div>
            )}
            <div>
              <h3>{m.name}</h3>
              <p class="role">{m.role}</p>
              <p class="focus">{m.focus}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Board & Advisory -->
  <section class="section">
    <div class="container">
      <div class="grid grid--2" style="gap:3rem; align-items:start;">
        <div>
          <p class="eyebrow">Founding Board</p>
          <h2>Governance &amp; oversight</h2>
          <p>
            AOP is governed by a founding board of directors with skills coverage across finance/audit,
            legal, education, athletics, fundraising, and community, with an independent treasurer separate
            from the Board Chair. The board reviews our North Star outcomes dashboard quarterly.
          </p>
          <p class="note">Board roster is being finalized as part of our formation sprint. Interested in serving?
            <a href="/get-involved/">Join the founding board.</a></p>
        </div>
        <div>
          <p class="eyebrow">Advisory Council</p>
          <h2>Guidance from the field</h2>
          <p>
            Our advisory council brings expertise in college advising, financial aid, youth protection, and
            employer partnerships to keep AOP's model rigorous and evidence-based.
          </p>
          <p class="note">Advisory council members will be announced soon.</p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .founder {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }
  .founder h2 {
    margin-top: 0;
  }
  .founder p:last-child {
    margin-bottom: 0;
  }
  .founder-quote {
    margin: 1.5rem 0 0;
    padding: 1rem 0 1rem 1.5rem;
    border-left: 4px solid var(--gold);
    font-size: 1.25rem;
    font-weight: 500;
    font-style: italic;
    color: var(--navy);
    line-height: 1.4;
  }
  .founder-quote cite {
    display: block;
    margin-top: 0.6rem;
    font-size: 0.95rem;
    font-style: normal;
    font-weight: 700;
    color: var(--gold-dark);
  }
  .avatar {
    flex: 0 0 auto;
    width: 84px;
    height: 84px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--navy);
    color: var(--gold-light);
    font-family: var(--font-display);
    font-size: 1.8rem;
    letter-spacing: 0.03em;
  }
  .avatar--lg {
    width: 130px;
    height: 130px;
    font-size: 2.8rem;
  }
  .avatar--photo {
    object-fit: cover;
    object-position: center 30%;
  }
  .role {
    color: var(--gold-dark);
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  /* Equal-height rows so a lone card in the last row matches the others */
  .team-grid {
    grid-auto-rows: 1fr;
  }
  .mentor {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .mentor .focus {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin: 0;
  }
  .note {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  @media (max-width: 560px) {
    .founder {
      flex-direction: column;
      text-align: center;
      gap: 1rem;
    }
  }
</style>
