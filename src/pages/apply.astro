---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../config';
---

<Base title="Apply to AOP" description="Application for students who want to become an AOP scholar: academic support, mentorship, athletic development, and college and career planning.">
  <PageHero
    eyebrow="Student Application"
    title="Become an AOP scholar"
    intro="Athletes of Promise supports NYC student-athletes, and students with athletic aspirations, in grades 6 through 12. Tell us about the student below and our team will follow up about next steps."
  />

  <section class="section">
    <div class="container narrow">
      <p class="lead">
        A parent or guardian should complete this application with the student. Everything you share stays
        private, and submitting it is the first step, not a commitment.
      </p>

      <form class="form" action={`https://formsubmit.co/${site.email}`} method="POST">
        <input type="hidden" name="_subject" value="New student application, AOP website" />
        <input type="text" name="_honey" style="display:none" />

        <h2 class="form__heading">Student</h2>
        <div class="form__row">
          <label>
            Student's full name
            <input type="text" name="student_name" required autocomplete="name" />
          </label>
          <label>
            Grade (2026–27)
            <select name="grade" required>
              <option value="">Choose one…</option>
              <option>6th</option>
              <option>7th</option>
              <option>8th</option>
              <option>9th</option>
              <option>10th</option>
              <option>11th</option>
              <option>12th</option>
            </select>
          </label>
        </div>
        <div class="form__row">
          <label>
            Current school
            <input type="text" name="school" />
          </label>
          <label>
            Sport(s) or athletic interest
            <input type="text" name="sport" placeholder="e.g. track & field, softball, flag football" />
          </label>
        </div>

        <h2 class="form__heading">Parent or guardian</h2>
        <div class="form__row">
          <label>
            Parent / guardian name
            <input type="text" name="guardian_name" required />
          </label>
          <label>
            Best phone number
            <input type="tel" name="guardian_phone" autocomplete="tel" />
          </label>
        </div>
        <label>
          Email
          <input type="email" name="guardian_email" required autocomplete="email" />
        </label>

        <label>
          Anything you'd like us to know?
          <textarea name="message" rows="5" placeholder="Goals, questions, or how you heard about AOP."></textarea>
        </label>

        <button class="btn btn--gold" type="submit">Submit application</button>
        <p class="form__note">
          By submitting you agree to be contacted by AOP Foundation about the student's application.
          We never share your information.
        </p>
      </form>
    </div>
  </section>
</Base>

<style>
  .narrow {
    max-width: 720px;
  }
  .form {
    margin-top: 1.5rem;
    display: grid;
    gap: 1.1rem;
  }
  .form__heading {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.05rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gold-dark);
    margin: 0.8rem 0 0;
  }
  .form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
  }
  .form label {
    display: grid;
    gap: 0.35rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--navy);
  }
  .form input,
  .form select,
  .form textarea {
    font-family: inherit;
    font-size: 1rem;
    padding: 0.7rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: #fff;
  }
  .form input:focus,
  .form select:focus,
  .form textarea:focus {
    border-color: var(--gold);
    outline: none;
  }
  .form__note {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
  }
  @media (max-width: 560px) {
    .form__row {
      grid-template-columns: 1fr;
    }
  }
</style>
